{
  "name": "archi",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first Kindle to Notion sync desktop app",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @archi/desktop dev",
    "dev:renderer": "pnpm --filter @archi/desktop dev:renderer",
    "healthcheck": "pnpm --filter @archi/desktop healthcheck",
    "lint": "pnpm -r lint",
    "postinstall": "pnpm --filter @archi/desktop rebuild:native",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.18",
    "eslint": "^9.27.0",
    "typescript-eslint": "^8.33.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "playwright",
      "playwright-core"
    ]
  }
}
