# Flat (npm-style) node_modules. Required so electron-builder bundles the FULL
# transitive dependency tree of @xenova/transformers / onnxruntime-node /
# onnxruntime-web into the packaged app. With pnpm's default isolated linker,
# electron-builder's dependency walk only collects the app's DIRECT deps and
# silently strips transitive ones (onnxruntime-common, flatbuffers, protobufjs,
# …), which made packaged semantic search crash at runtime. See skill:
# xenova-transformers-electron-strips-jinja-onnx-web-sharp
node-linker=hoisted
