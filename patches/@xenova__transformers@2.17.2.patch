+// Will be empty (or not used) if running in browser or web-worker.
+//
+// PATCH (Archi): sharp is only used for image decoding, which this app never
+// does (text-only feature-extraction). Upstream imports it statically, which
+// makes the WHOLE transformers package unloadable whenever sharp's native
+// binary/libvips/transitive deps aren't bundled — exactly what happens in our
+// pnpm + electron-builder packaged build. Load it optionally instead: if sharp
+// (or its native binary) can't load, `sharp` stays null and the `else if
+// (sharp)` guards below fall through harmlessly. Avoids bundling a ~10MB native
+// libvips we never call.
+import { createRequire as __archiCreateRequire } from 'module';
+let sharp = null;
+try {
+    sharp = __archiCreateRequire(import.meta.url)('sharp');
+} catch {
+    sharp = null;
+}
 
 const BROWSER_ENV = typeof self !== 'undefined';
 const WEBWORKER_ENV = BROWSER_ENV && self.constructor.name === 'DedicatedWorkerGlobalScope';
@@ -51,7 +66,14 @@ if (BROWSER_ENV) {
     }
 
 } else {
-    throw new Error('Unable to load image processing library.');
+    // PATCH (Archi): upstream throws here at MODULE-INIT when sharp is
+    // unavailable, which breaks `import('@xenova/transformers')` entirely — even
+    // for text-only feature-extraction that never decodes an image. Defer the
+    // error to an actual image-load call (which this app never makes) so the
+    // module loads and text embeddings work without sharp.
+    loadImageFunction = async () => {
+        throw new Error('Image processing unavailable: sharp is not bundled in this text-only build.');
+    };
