---
const steps = [
  {
    title: "Sign in once.",
    body: "A two-minute guided setup walks you through Kindle and, if you want, Notion.",
  },
  {
    title: "Archi pulls them in.",
    body: "Your highlights and notes live on your Mac. No servers, nothing uploaded.",
  },
  {
    title: "Search by meaning.",
    body: "Semantic + keyword search across every highlight. Find similar passages in one click. Send to Notion when you want it there.",
  },
];
---
<section id="how-it-works" class="mx-auto max-w-[1080px] px-6 py-10 md:py-14 lg:py-20">
  <p class="text-xs uppercase tracking-[0.18em] text-ink-500 mb-3">How it works</p>
  <h2 class="font-serif text-[26px] md:text-[40px] tracking-[-0.015em] text-ink-900 mb-10 md:mb-12 max-w-[20ch]">Three steps, then it's just there.</h2>

  <ol class="grid gap-4 md:gap-6 md:grid-cols-3">
    {steps.map((step, i) => (
      <li class="bg-paper-white border border-ink-100 rounded-[14px] p-5 md:p-6">
        <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-paper-200 text-ink-700 font-serif text-sm mb-4">{i + 1}</span>
        <h3 class="font-serif text-[19px] md:text-[20px] text-ink-900 mb-2 leading-tight">{step.title}</h3>
        <p class="text-sm text-ink-500 leading-relaxed">{step.body}</p>
      </li>
    ))}
  </ol>
</section>
